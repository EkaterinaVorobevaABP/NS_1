    {
      "cell_type": "code",
      "execution_count": null,
      "id": "f7d6bfd3-348d-46b6-8f38-9f4aebd4561c",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "f7d6bfd3-348d-46b6-8f38-9f4aebd4561c",
